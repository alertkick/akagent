# Build artifacts
build/
dist/
third_party_licenses/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.deb
*.rpm
*.msi

# Compiled binaries (anchored to repo root so the same names under
# packaging/ — which are sysv init scripts, not Go binaries — stay tracked)
/main
/alertkick-agent

# Demo/test data
demo-security-events/

# Test artifacts
*.test
*.out
coverage.html
coverage.txt

# Dependency directories (use go modules)
vendor/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Configuration files with credentials at runtime
*.conf
# Packaging templates carry the same extension but ship with the agent —
# they are NOT credentials and must be tracked for goreleaser to build
# the deb/rpm packages.
!packaging/**/*.conf

# Runtime generated files
machine-id
*.log
*.pid

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.old
*config.json
agent_checks.json

# API related
apapi
devtools
*.http
